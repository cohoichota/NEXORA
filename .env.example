# ═══════════════════════════════════════════════════════════════════
# Nexora — Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env.local or .env.prod with real secrets
# ═══════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=change_me_in_local
POSTGRES_DB=nexora_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_local
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ── MinIO (Object Storage) ──────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_local
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_PRODUCTS=products
MINIO_BUCKET_AVATARS=avatars

# ── Kafka ───────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:29092
SCHEMA_REGISTRY_URL=http://localhost:8081

# ── OpenSearch ──────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PASSWORD=Admin_password123!
OPENSEARCH_INDEX_PRODUCTS=products

# ── Auth / JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# ── OAuth ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Payments ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ── Notifications ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@nexora.dev
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# ── AI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── App URLs ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Service Ports ───────────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
PRODUCT_SERVICE_PORT=3003
INVENTORY_SERVICE_PORT=3004
CART_SERVICE_PORT=3005
ORDER_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
SEARCH_SERVICE_PORT=3009
RECOMMENDATION_SERVICE_PORT=3010
ANALYTICS_SERVICE_PORT=3011
API_GATEWAY_PORT=4000

# ── Service URLs (internal, for inter-service communication) ─────────
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3003
INVENTORY_SERVICE_URL=http://localhost:3004
CART_SERVICE_URL=http://localhost:3005
ORDER_SERVICE_URL=http://localhost:3006
PAYMENT_SERVICE_URL=http://localhost:3007

# ── Observability ───────────────────────────────────────────────────
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=nexora
LOG_LEVEL=debug

# ── Environment ─────────────────────────────────────────────────────
NODE_ENV=development
