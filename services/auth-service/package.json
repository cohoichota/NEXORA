  "devDependencies": {
    "@nexora/eslint-config": "workspace:*",
    "@nexora/tsconfig": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
