{
  "name": "@nexora/recommendation-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nexora/kafka-events": "workspace:*",
    "@nexora/shared-types": "workspace:*",
    "@nexora/shared-utils": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nexora/eslint-config": "workspace:*",
    "@nexora/tsconfig": "workspace:*",
    "@types/node": "^20.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
