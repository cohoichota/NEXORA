{
  "name": "@nexora/product-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/microservices": "^10.4.22",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^5.2.0",
    "@nexora/kafka-events": "workspace:*",
    "@nexora/shared-types": "workspace:*",
    "@nexora/shared-utils": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kafkajs": "^2.2.4",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nexora/eslint-config": "workspace:*",
    "@nexora/tsconfig": "workspace:*",
    "@types/node": "^20.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
