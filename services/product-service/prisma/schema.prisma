// ═══════════════════════════════════════════════════════════════
// Nexora — Product Service Prisma Schema
// Manages: products, categories, images, variants
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Category ──────────────────────────────────────────────────

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

// ── Product ───────────────────────────────────────────────────

model Product {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  description String
  shortDesc   String?
  sellerId    String        // References user in auth-service
  categoryId  String
  status      ProductStatus @default(PENDING)
  brand       String?
  tags        String[]

  basePrice   Decimal       @db.Decimal(12, 2)
  comparePrice Decimal?     @db.Decimal(12, 2) // strike-through price
  currency    String        @default("USD")

  weight      Float?
  dimensions  Json?         // { length, width, height, unit }

  rating      Float         @default(0)
  reviewCount Int           @default(0)

  isDigital   Boolean       @default(false)
  isFeatured  Boolean       @default(false)

  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category Category       @relation(fields: [categoryId], references: [id])
  images   ProductImage[]
  variants ProductVariant[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([slug])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
  @@map("products")
}

enum ProductStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

// ── Product Images ────────────────────────────────────────────

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ── Product Variants ──────────────────────────────────────────
// Each variant = a unique SKU (e.g., "Red / XL")

model ProductVariant {
  id         String   @id @default(uuid())
  productId  String
  sku        String   @unique
  title      String   // e.g., "Red / XL"
  price      Decimal  @db.Decimal(12, 2)
  attributes Json     // { "color": "red", "size": "XL" }
  imageUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}
